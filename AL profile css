h1 {
   font-family: gabriola, noto, trebuchet ms !important;
   font-size: 28px !important;
   font-weight: bold;
}

h2 {
    font-family: trebuchet ms, noto;
    color: rgba(255,255,240,0.8);
}

p {
    font-family: Trebuchet MS;
    font-size: 14px;
}

/*Cursor*/
* {
  cursor: url(https://i.imgur.com/cn2zbB2.png), auto;
}
a[href], input[type='submit'], input[type='image'], label[for], select, button, .pointer {
  cursor: url(https://i.imgur.com/dX5hqN6.png), auto;
}
a, a:link img {
  cursor: url(https://i.imgur.com/dX5hqN6.png), auto !important;
}                    

/* Background image (change the URL to change the image) */
body {
    background: rgb(var(--color-background)) url("https://i.imgur.com/TU1Umee.png") center/100% fixed;
    background-repeat: no-repeat !important;
    background-size: cover !important;
}

/* Banner - use together with background image */
.banner {
    background-image: none !important;
    background-color: rgba(36, 37, 56,0) !important;
    height: auto !important;
}

.banner .shadow{
    background: none !important;
}

/* changes the top navbar */

/*HEEEEERRRRREEEEEE*/
#nav {
  background: rgba(21,31,46,0.9) !important;
  border-radius: 0 20px 20px 0;
  left: /*calc((100% - 80%) / 2)*/ 10%;
  width: 80%;
  justify-content: center;
  transition: background 0.5s ease 0s, top 0.5s ease 0s !important;
  backdrop-filter: blur(4px);
  height: 60px;
}

/* search section fix(only use with the code above) */
.quick-search.visible {
  left: auto;
}

/* nav buttons hover */
#nav .link {
  transition: transform 0.69s ease-in-out;
}

#nav .link:hover {
  transform: scale(1.2);
  color: #4ABD4E
}  /*HEEEEERRRRREEEEEE*/


.activity-message .text {
  border-left: solid 3px #00bfa8 ; 
}

.activity-text .text {
  border-left: solid 3px #1AC100; 
}

/* favourites section */
.favourite {
    transition: transform 5s linear;
    border-radius: 20%;
    position: static;
}

/* favourites section hover - it scales! */
.favourite:hover {
    transform: scale(1.2); 
    transform-origin: top; 
    position: relative;
    z-index: 3;
    transition: 0.3s;
    transform-style: inherit;
}

/*  favourites section wrapping */
.favourites-wrap.anime,
.favourites-wrap.manga,
.favourites-wrap.characters,
.favourites-wrap.staff,
.favourites-wrap.studios {
    overflow: visible;
}

h2.section-header {
    font-family: trebuchet ms, noto;
    color: rgba(255,255,240,0.8);
    font-size: 16px;
}

.user .about > div.content-wrap {
    background-color: rgba(21,31,46,1);
}

/* About section scrollbar
.user .about {
    scrollbar-width: 0 !important;
} */

.section-header[data-v-09492909]::before {
  transition: transform .7s ease-in-out;
  visibility: visible;
  content: "Inori's";
  color: rgba(255,255,240,0.8);
}

.activity-markdown:after {
  content: "(◕‿◕✿)                   ";
  white-space: pre-wrap;
  font-family: trebuchet ms !important;
  justify-content: flex-end;
  display: flex;
  color: #67db6a;
}

/* Profile activity (status/messages/list) Makes border corners rounded. */
.wrap, .reply {
    font-family: Trebuchet MS;
    font-size: 20px;
    border-bottom-right-radius: 20px !important;
    border-top-right-radius: 20px !important;
    overflow: visible !important;
}

/* Anime/manga displaying rounded corners, part 2 */
.cover {
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
}
.list-stats {
    border-bottom-right-radius: 20px !important;
    border-top-right-radius: 20px !important;
}

/* Horizontal rule border settings */
.markdown hr {
    border: solid 1.4px #4DAA22;
    border-radius: 2px;
}

/* Blockquotes*/
.markdown blockquote {
    margin-right: 10px; 
}

/* Site background color transparency */
.site-theme-dark {
    --color-foreground: 16, 24, 35, 0.85; 
}

/*Hides hoh download button*/
.hohDownload {
    display: none;
}

/* Changes scrollbar for whole page (Firefox)*/
html {
    scrollbar-width: thin;
}

/* Chrome scrollbar */
::-webkit-scrollbar {
    width: 6px;
    background: rgb(0,0,0,0);
}

::-webkit-scrollbar-corner {
    background: rgb(0,0,0,0);
}
::-webkit-scrollbar-thumb {
    background: #4DAA22;
    -webkit-border-radius: 1ex;
}
::-webkit-scrollbar-thumb:hover {
  background: #479920;
}

/* hide about section scrollbar */
.about .content-wrap[data-v-5c30286e]::-webkit-scrollbar {
  background-color: rgba(255, 255, 255, 0);
  width: 4px
}

.about .content-wrap[data-v-5c30286e]::-webkit-scrollbar-track {
  background-color: rgba(255, 255, 255, 0);
}

.about .content-wrap[data-v-5c30286e]::-webkit-scrollbar-thumb {
  background-color: rgba(196, 196, 240, 0.20);
  border-radius: 10px;
}


/* Modifies load-more button */
.load-more {
    border-bottom-right-radius: 30px !important;
    border-top-right-radius: 30px !important;
    border-top-left-radius: 0px !important;
    border-bottom-left-radius: 0px !important;
    font-family: trebuchet ms !important;
    font-size: 15px !important;
    margin: auto !important;
    max-width: 200px !important;
}

/* Changes "Overview/Anime List/Manga List..." nav section. - shorter navbar*/
.nav-wrap {
    background: rgb(var(--color-foreground)) !important;
    width: 68% !important;
    margin: 0 auto !important;
    border-top-right-radius: 30px !important;
    border-bottom-right-radius: 30px !important;
}

.nav-wrap .link:hover {
    transform: scales(1.2);
    color: #93d89a;
}

img.avatar,
h1.name {
    margin: auto;
}

/* Re-aligns profile picture and name. */
.banner-content {
    box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.5);
    transition: 0.3s;
    width: auto !important;
    background-color: rgb(var(--color-foreground));
    padding: 10px;
    border-radius: 30px !important;
    margin: auto;
    flex-direction: row;
    margin-top: 80px;
    margin-bottom: 10px
}

.activity-feed-wrap {
    margin-left: 2%;
}
.stats-wrap {
    margin-left: 2%;
    margin-right: 0%;
}

/** Main avatar. */
.avatar {
    border-radius: 100%;
    transition: transform 2s;
}

/* avatar */
a[class="avatar"],
a[class="avatar router-link-exact-active router-link-active"] {
    transition: transform 1s !important;
}
/* avatar hover */
a[class="avatar"]:hover,
a[class="avatar router-link-exact-active router-link-active"]:hover {
    transform: scale(2.5) !important; 
    transition: transform 0.3s; 
    transform-style: preserve-3d;
}

div.overview {
    background-color: rgba(0,0,,0,0.9);
}

