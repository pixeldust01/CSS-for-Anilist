h1 {
   font-family: gabriola, noto, trebuchet ms !important;
   font-size: 28px !important;
}

p {
    font-family: Trebuchet MS;
    font-size: 14px;
}

/* Background image (change the URL to change the image) */
body {
    background: rgb(var(--color-background)) url("https://i.imgur.com/H9bFLyd.png") center/100% fixed;
    background-repeat: no-repeat !important;
    background-size: cover !important;
}

/* Transparent banner - use together with background image */
.banner {
    background-image: none !important;
    background-color: rgba(36, 37, 56,0) !important;
    height: auto !important;
}
.banner .shadow{
    background: none !important;
}

.activity-message .text {
  border-left: solid 3px #00bfa8 ; 
}

.activity-text .text {
  border-left: solid 3px #1AC100; 
}

/* favourites section */
.favourite {
    transition: transform 5s linear;
    border-radius: 20%;
    position: static;
}

/* favourites section hover - it scales! */
.favourite:hover {
    transform: scale(1.4, 1.4); 
    transform-origin: top; 
    position: relative;
    z-index: 3;
    transition: 0.7s;
    transform-style: preserve-3d;
}

/*  favourites section wrapping */
.favourites-wrap.anime,
.favourites-wrap.manga,
.favourites-wrap.characters,
.favourites-wrap.staff,
.favourites-wrap.studios {
    overflow: visible;
}

/* About section scrollbar */
.user .about > div.content-wrap:hover {
    scrollbar-width: thin;
}

/* Profile activity (status/messages/list) Makes border corners rounded. Also required as bugfix for .avatar hover! */
.wrap,
.reply {
    font-family: Trebuchet MS;
    font-size: 20px;
    border-bottom-right-radius: 20px !important;
    border-top-right-radius: 20px !important;
    overflow: visible !important;
}

/* Anime/manga displaying rounded corners, part 2 */
.cover {
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
}
.list-stats {
    border-bottom-right-radius: 20px !important;
    border-top-right-radius: 20px !important;
}

/* Horizontal rule border settings */
.markdown hr {
    border: solid 1.4px #4DAA22;
    border-radius: 1px;
}

/* Blockquotes*/
.markdown blockquote {
    margin-right: 10px; 
}

/* Site background color transparency */
.site-theme-dark {
    --color-foreground: 16, 24, 35, .90; 
}

/*Hides hoh download button*/
.hohDownload {
    display: none;
}

/* Changes scrollbar for whole page (Firefox)*/
html {
    scrollbar-width: thin;
}

/* Chrome scrollbar */
::-webkit-scrollbar {
    width: 6px;
    background: rgb(0,0,0,0);
}

::-webkit-scrollbar-corner {
    background: rgb(0,0,0,0);
}
::-webkit-scrollbar-thumb {
    background: #4DAA22;
    -webkit-border-radius: 1ex;
}
::-webkit-scrollbar-thumb:hover {
  background: #479920;
}

/* Modifies load-more button */
.load-more {
    border-bottom-right-radius: 30px !important;
    border-top-right-radius: 30px !important;
    border-top-left-radius: 0px !important;
    border-bottom-left-radius: 0px !important;
    font-family: trebuchet ms !important;
    font-size: 15px !important;
    margin: auto !important;
    max-width: 400px !important;
}

/* Changes "Overview/Anime List/Manga List..." nav section. - shorter navbar*/
.nav-wrap {
    background: rgb(var(--color-foreground)) !important;
    width: 68% !important;
    margin: 0 auto !important;
    border-top-right-radius: 30px !important;
    border-bottom-right-radius: 30px !important;
}

img.avatar,
h1.name {
    margin: auto;
}

/* Re-aligns profile picture and name. */
.banner-content {
    box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.5);
    transition: 0.3s;
    width: auto !important;
    background-color: rgb(var(--color-foreground));
    padding: 10px;
    border-radius: 30px !important;
    margin: auto;
    flex-direction: row;
    margin-top: 80px;
    margin-bottom: 10px
}

.activity-feed-wrap {
    margin-left: 2%;
}
.stats-wrap {
    margin-left: 2%;
    margin-right: 0%;
}

/** Main avatar. */
.avatar {
    border-radius: 100%;
    transition: transform 2s;
}

/* avatar */
a[class="avatar"],
a[class="avatar router-link-exact-active router-link-active"] {
    transition: transform 1s !important;
}
/* avatar hover */
a[class="avatar"]:hover,
a[class="avatar router-link-exact-active router-link-active"]:hover {
    transform: scale(2) !important; 
    transition: transform 0.7s; 
    transform-style: preserve-3d;
}

/* Adds a fixed image to the bottom-right hand corner of the screen. Note: This image cannot be resized, make sure you resize the image before using it*/
#nav::after {
    content: url(https://i.imgur.com/WIsh1x7.png);
    object-position: bottom left;
    position: fixed;
    bottom: 0; right: 0;
}

/* Mobile (small screen size) only: */
@media (max-width: 760px) {

    /* InoriofRain */
    .name-wrapper {
        position: relative;
        bottom: 5px;
    } }

/** PC (standard screen size) only: */
@media (min-width: 761px) {
    /*Donator badge*/
    .nav-btn {
        position: relative;
        bottom: 0px;
        top: -43px;
        right: 20px;
    }


    /* InoriofRain */
    .name-wrapper {
        position: relative;
        bottom: 40px;
    }
}


/* Makes box invisible for profile pic and username. */
.banner-content {
    box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.0);
    background-color: rgba(16, 24, 35, 0.0);
} 
